# Standard Farmer-like walled cavity preset for doseLab.
# Use before /run/initialize in batch or visualization macros.

/doseLab/scenario/type farmer_walled
/doseLab/cavity/material G4_AIR
/doseLab/cavity/wallMaterial G4_PLEXIGLASS
# Water test override (both cavity and wall):
# /doseLab/cavity/material G4_WATER
# /doseLab/cavity/wallMaterial G4_WATER
/doseLab/cavity/print
