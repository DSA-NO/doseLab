# Approximate 6 MV linac photon source model (source identity only).
# This is a pragmatic first-pass spectrum for relative dosimetry studies.

/doseLab/output/source 6mv

/gps/particle gamma

/gps/ene/type User
/gps/hist/type energy
/gps/hist/point 0.20 0.15
/gps/hist/point 0.50 0.40
/gps/hist/point 1.00 0.85
/gps/hist/point 1.50 1.00
/gps/hist/point 2.00 0.95
/gps/hist/point 3.00 0.70
/gps/hist/point 4.00 0.45
/gps/hist/point 5.00 0.22
/gps/hist/point 6.00 0.08
