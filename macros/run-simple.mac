# Quick debug run for current doseLab GPS+cavity setup.
# Use this for smoke tests and interactive checks.
#
# Composition order:
# 1) cavity preset
# 2) run initialize
# 3) source setup
# 4) beamOn

# Optional:
# /run/numberOfThreads 4

# Chamber preset
/control/execute cavity-farmer.mac

/run/initialize

# Configure Co-60 GPS source
/control/execute source.mac

# Quick event sample
/run/printProgress 20
/run/beamOn 200
