/doseLab/output/tag vis-ref-10x10-d5cm-6mv-roos-walled

# Visualization run: 10x10 cm^2, depth = 5cm water-equivalent, 6 MV source, roos-like walled chamber.
# Fires a small number of events to display tracks without collecting statistics.

/control/execute cavity-roos-walled.mac
/control/execute depth-ref-5cm-center.mac

/run/initialize

/control/execute vis.mac

/control/execute source-linac-photons-6mv.mac
/control/execute field-ref-10x10-ssd100.mac

/run/printProgress 1
/run/beamOn 5
