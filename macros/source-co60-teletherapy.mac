# Co-60 teletherapy source model (source identity only).
# This macro intentionally defines particle and energy spectrum only.

/doseLab/output/source co60

/gps/particle gamma

# Co-60 photon lines (MeV) with realistic relative intensities.
# Intensities are very close but not exactly equal in evaluated data.
/gps/ene/type User
/gps/hist/type energy
/gps/hist/point 1.1732 0.9985
/gps/hist/point 1.3325 0.9998
