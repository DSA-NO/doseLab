# Initialization macro for interactive doseLab visualization.
#
# Set default verbosity.
/control/verbose 2
/control/saveHistory
/run/verbose 2
#
# Optional: change thread count in multi-threaded mode.
#/run/numberOfThreads 4
#
# Note: geometry-sensitive cavity commands should be set before /run/initialize
# to avoid visualization scene mismatches during live geometry rebuild.
#
# Typical sequence in interactive mode:
# /doseLab/cavity/type farmer
# /run/initialize
# /control/execute vis.mac
